{
  "name": "example-consumer-project",
  "version": "0.0.0",
  "description": "Example app pulling in skills from its dependencies via skill-indexer.",
  "private": true,
  "scripts": {
    "sync-skills": "skill-indexer install",
    "postinstall": "skill-indexer install --dry-run || true"
  },
  "devDependencies": {
    "skill-indexer": "^0.1.0"
  },
  "skillIndexer": {
    "targets": ["cursor", "codex", "claude"],
    "include": [],
    "exclude": ["legacy-pkg-with-noisy-skills-folder"],
    "overwrite": "skip",
    "onConflict": "first-wins"
  }
}
